# ──────────────────────────────────────────────────────────────
# Aegis — environment configuration template
# Copy to .env and fill in real values.  NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────

# ── Core ──
APP_NAME=Aegis
DEBUG=false
LOG_LEVEL=INFO
LOG_DIR=logs

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./data/aegis.db

# ── JWT ──
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_EXPIRY_MINUTES=60

# ── Security ──
SECURITY_KEYSTORE_PATH=data/security/keystore.bin
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECURITY_KEYSTORE_PASSPHRASE=REPLACE_WITH_STRONG_PASSPHRASE
SECURITY_BACKUP_PASSPHRASE=REPLACE_WITH_DIFFERENT_STRONG_PASSPHRASE

# ── Storage ──
MODELS_DIR=models
DATA_DIR=data
BACKUP_DIR=data/backups
