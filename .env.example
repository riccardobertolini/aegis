# ============================================================
# Aegis — Environment Configuration Example
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# Runtime
AEGIS_ENV=development          # development | production
AEGIS_LOG_LEVEL=INFO
AEGIS_LOG_DIR=./logs

# Backend
AEGIS_HOST=0.0.0.0
AEGIS_PORT=8000
AEGIS_SECRET_KEY=change-me-min-32-chars-random
AEGIS_JWT_ALGORITHM=HS256
AEGIS_JWT_EXPIRE_MINUTES=480

# Database
AEGIS_DB_PATH=./data/aegis.db
AEGIS_DUCKDB_PATH=./data/analytics.duckdb

# Vector store
AEGIS_CHROMA_PATH=./data/chroma

# Model storage (local path)
AEGIS_MODELS_DIR=./models

# Document storage
AEGIS_DOCS_DIR=./data/documents
AEGIS_INDEX_DIR=./data/indexes
